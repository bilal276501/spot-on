---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Online Calculator — Free Online Calculator & Converter Tools | SpotOn"
  description="Use our free online calculator for everyday, scientific, percentage & BMI maths, plus a full online converter suite for length, weight, temperature and more. The best free online calculator — fast, accurate, no sign-up required."
  keywords="online calculator, free online calculator, best online calculator, online calculator free, best free online calculator, online converter"
>

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-badge">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><circle cx="5" cy="5" r="5" fill="#50e3c2"/></svg>
        Free · No sign-up · Works everywhere
      </div>
      <h1 class="display-xl hero-title">The free online calculator<br/>that just works.</h1>
      <p class="body-lg hero-subtitle">
        Our free online calculator handles everyday, scientific and percentage maths in seconds, and our online converter suite covers units, currencies and more — all with no sign-up.
      </p>
      <div class="hero-actions">
        <a href="/calculators/simple/" class="btn-primary">Open Calculator</a>
        <a href="/calculators/scientific/" class="btn-secondary">Scientific Mode</a>
      </div>
    </div>
  </section>

  <!-- Live Simple Calculator Preview -->
  <section class="section section-soft" id="calculator">
    <div class="container" style="display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center;">
      <div>
        <p class="section-eyebrow">Fullscreen Calculator</p>
        <h2 class="display-lg section-title">The online calculator that just works.</h2>
        <p class="body-md section-subtitle">No clutter. No ads. No distractions. A clean, fast calculator available free in your browser — or expand it to fullscreen for total focus.</p>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <a href="/calculators/simple/" class="btn-primary">Open Fullscreen</a>
          <a href="/calculators/scientific/" class="btn-secondary">Try Scientific</a>
        </div>
      </div>
      <div>
        <div class="calc-container" id="hero-calc">
          <div class="calc-display">
            <div class="calc-expression" id="hc-expr"></div>
            <div class="calc-result" id="hc-result">0</div>
          </div>
          <div class="calc-buttons">
            <button class="calc-btn clear" data-val="C">C</button>
            <button class="calc-btn op" data-val="±">±</button>
            <button class="calc-btn op" data-val="%">%</button>
            <button class="calc-btn op" data-val="÷">÷</button>
            <button class="calc-btn" data-val="7">7</button>
            <button class="calc-btn" data-val="8">8</button>
            <button class="calc-btn" data-val="9">9</button>
            <button class="calc-btn op" data-val="×">×</button>
            <button class="calc-btn" data-val="4">4</button>
            <button class="calc-btn" data-val="5">5</button>
            <button class="calc-btn" data-val="6">6</button>
            <button class="calc-btn op" data-val="−">−</button>
            <button class="calc-btn" data-val="1">1</button>
            <button class="calc-btn" data-val="2">2</button>
            <button class="calc-btn" data-val="3">3</button>
            <button class="calc-btn op" data-val="+">+</button>
            <button class="calc-btn span2" data-val="0">0</button>
            <button class="calc-btn" data-val=".">.</button>
            <button class="calc-btn equals" data-val="=">=</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools Grid -->
  <section class="section" id="tools">
    <div class="container">
      <p class="section-eyebrow">All Tools</p>
      <h2 class="display-lg section-title">Every calculator you need.</h2>
      <p class="body-md section-subtitle">From everyday arithmetic to specialist converters — all free, all instant, all beautifully simple.</p>

      <div class="category-pills">
        <button class="pill active" data-filter="all">All</button>
        <button class="pill" data-filter="calc">Calculators</button>
        <button class="pill" data-filter="conv">Converters</button>
        <button class="pill" data-filter="math">Maths</button>
      </div>

      <div class="grid-4" id="tools-grid">
        <!-- Calculators -->
        <a href="/calculators/simple/" class="card card-link" data-cat="calc">
          <div class="card-icon card-icon-blue">🖩</div>
          <h3 class="body-sm-strong mb-sm">Simple Calculator</h3>
          <p class="body-sm text-body">Fast, clean everyday calculator for basic arithmetic.</p>
        </a>
        <a href="/calculators/scientific/" class="card card-link" data-cat="calc math">
          <div class="card-icon card-icon-purple">🔬</div>
          <h3 class="body-sm-strong mb-sm">Scientific Calculator</h3>
          <p class="body-sm text-body">Trig, logarithms, powers and advanced maths functions.</p>
        </a>
        <a href="/calculators/fullscreen/" class="card card-link" data-cat="calc">
          <div class="card-icon card-icon-cyan">⛶</div>
          <h3 class="body-sm-strong mb-sm">Fullscreen Calculator</h3>
          <p class="body-sm text-body">Distraction-free fullscreen mode — perfect on any screen.</p>
        </a>
        <a href="/calculators/abacus/" class="card card-link" data-cat="calc math">
          <div class="card-icon card-icon-orange">🧮</div>
          <h3 class="body-sm-strong mb-sm">Online Abacus</h3>
          <p class="body-sm text-body">Interactive abacus for learning and mental arithmetic.</p>
        </a>
        <a href="/calculators/bmi/" class="card card-link" data-cat="calc">
          <div class="card-icon card-icon-blue">⚖️</div>
          <h3 class="body-sm-strong mb-sm">BMI Calculator</h3>
          <p class="body-sm text-body">Calculate your Body Mass Index with metric or imperial units.</p>
        </a>
        <a href="/calculators/percentage/" class="card card-link" data-cat="calc math">
          <div class="card-icon card-icon-purple">%</div>
          <h3 class="body-sm-strong mb-sm">Percentage Calculator</h3>
          <p class="body-sm text-body">Work out percentages, discounts and percentage changes.</p>
        </a>
        <a href="/calculators/patio/" class="card card-link" data-cat="calc">
          <div class="card-icon card-icon-orange">🏗️</div>
          <h3 class="body-sm-strong mb-sm">Patio Calculator</h3>
          <p class="body-sm text-body">Calculate materials, area and cost for patio and tiling projects.</p>
        </a>
        <a href="/calculators/darts/" class="card card-link" data-cat="calc">
          <div class="card-icon card-icon-cyan">🎯</div>
          <h3 class="body-sm-strong mb-sm">Darts Calculator</h3>
          <p class="body-sm text-body">Real-time darts scorer and checkout calculator for all formats.</p>
        </a>
        <a href="/calculators/maths/" class="card card-link" data-cat="calc math">
          <div class="card-icon card-icon-blue">∑</div>
          <h3 class="body-sm-strong mb-sm">Maths Calculator</h3>
          <p class="body-sm text-body">Equations, algebra, fractions and advanced maths tools.</p>
        </a>
        <!-- Converters -->
        <a href="/converters/length/" class="card card-link" data-cat="conv">
          <div class="card-icon card-icon-purple">📏</div>
          <h3 class="body-sm-strong mb-sm">Length Converter</h3>
          <p class="body-sm text-body">Metres, feet, inches, miles, km and more.</p>
        </a>
        <a href="/converters/weight/" class="card card-link" data-cat="conv">
          <div class="card-icon card-icon-orange">🏋️</div>
          <h3 class="body-sm-strong mb-sm">Weight Converter</h3>
          <p class="body-sm text-body">Kilograms, pounds, stone, ounces and all weight units.</p>
        </a>
        <a href="/converters/temperature/" class="card card-link" data-cat="conv">
          <div class="card-icon card-icon-cyan">🌡️</div>
          <h3 class="body-sm-strong mb-sm">Temperature Converter</h3>
          <p class="body-sm text-body">Celsius, Fahrenheit, Kelvin conversions instantly.</p>
        </a>
        <a href="/converters/speed/" class="card card-link" data-cat="conv">
          <div class="card-icon card-icon-blue">💨</div>
          <h3 class="body-sm-strong mb-sm">Speed Converter</h3>
          <p class="body-sm text-body">MPH, km/h, m/s, knots and aviation speed units.</p>
        </a>
        <a href="/converters/volume/" class="card card-link" data-cat="conv">
          <div class="card-icon card-icon-purple">🧪</div>
          <h3 class="body-sm-strong mb-sm">Volume Converter</h3>
          <p class="body-sm text-body">Litres, gallons, fluid ounces, cups and more.</p>
        </a>
        <a href="/converters/time/" class="card card-link" data-cat="conv">
          <div class="card-icon card-icon-orange">⏱️</div>
          <h3 class="body-sm-strong mb-sm">Time Converter</h3>
          <p class="body-sm text-body">Seconds, minutes, hours, days, weeks and years.</p>
        </a>
        <a href="/converters/ring-size/" class="card card-link" data-cat="conv">
          <div class="card-icon card-icon-cyan">💍</div>
          <h3 class="body-sm-strong mb-sm">Ring Size Converter</h3>
          <p class="body-sm text-body">UK, US, EU and international ring size charts.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Dark stats band -->
  <section class="dark-band">
    <div class="container">
      <div style="text-align:center; margin-bottom:48px;">
        <p class="section-eyebrow" style="color:rgba(255,255,255,0.4);">Why SpotOn</p>
        <h2 class="display-lg" style="color:white;">Built for speed. Designed for clarity.</h2>
      </div>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number">17</div>
          <div class="stat-label">Free tools</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">0</div>
          <div class="stat-label">Ads ever</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">&lt;1s</div>
          <div class="stat-label">Load time</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">∞</div>
          <div class="stat-label">Free forever</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature highlights -->
  <section class="section">
    <div class="container">
      <p class="section-eyebrow">Why we're different</p>
      <h2 class="display-lg section-title">Everything your competitors get wrong, we got right.</h2>
      <div class="grid-3">
        <div class="card">
          <div class="card-icon card-icon-blue">⚡</div>
          <h3 class="display-sm mb-sm">Instant results</h3>
          <p class="body-sm text-body">No page reloads. Every calculation and conversion updates live as you type.</p>
        </div>
        <div class="card">
          <div class="card-icon card-icon-purple">📱</div>
          <h3 class="display-sm mb-sm">Works everywhere</h3>
          <p class="body-sm text-body">Fully responsive on any device. No app download needed — open and use.</p>
        </div>
        <div class="card">
          <div class="card-icon card-icon-orange">🔒</div>
          <h3 class="display-sm mb-sm">Private by default</h3>
          <p class="body-sm text-body">Everything runs in your browser. No data sent to servers, no tracking.</p>
        </div>
        <div class="card">
          <div class="card-icon card-icon-cyan">🎨</div>
          <h3 class="display-sm mb-sm">Clutter-free UI</h3>
          <p class="body-sm text-body">Clean, distraction-free design. No pop-ups, no upsells, no noise.</p>
        </div>
        <div class="card">
          <div class="card-icon card-icon-blue">♿</div>
          <h3 class="display-sm mb-sm">Accessible</h3>
          <p class="body-sm text-body">Full keyboard support and screen reader compatibility built in from day one.</p>
        </div>
        <div class="card">
          <div class="card-icon card-icon-purple">🌐</div>
          <h3 class="display-sm mb-sm">SEO-optimised</h3>
          <p class="body-sm text-body">Each tool has its own fast-loading page, perfect for bookmarking or sharing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SEO Content Section -->
  <section class="section" id="about">
    <div class="container" style="max-width:820px;">
      <p class="section-eyebrow">About This Tool</p>
      <h2 class="display-lg section-title">The Best Free Online Calculator, Built for Everyone</h2>
      <div class="body-md text-body" style="display:flex; flex-direction:column; gap:20px; margin-top:24px;">
        <p>
          Whenever you need to work something out quickly, an <strong>online calculator</strong> is usually faster than searching for a physical one or opening a spreadsheet. SpotOn Calculator was built around that simple idea: a <strong>free online calculator</strong> that opens instantly in your browser, works on any device, and never asks you to sign up, install anything, or hand over your data. Whether you're adding up a grocery bill, checking a tip, solving a scientific equation, or converting units for a recipe or a DIY project, you get a clean, accurate result in seconds — no ads, no clutter, no distractions getting in the way of the numbers.
        </p>

        <h3 class="display-sm mb-sm">A Free Online Calculator for Every Task</h3>
        <p>
          Not every calculation is the same, so we didn't build just one tool — we built a full toolkit. Our <strong>online calculator free</strong> collection includes a simple everyday calculator for quick sums, a scientific calculator for trigonometry, logarithms and exponents, a percentage calculator for discounts and markups, a BMI calculator for health tracking, and specialist tools like our darts checkout calculator and patio materials calculator. Every one of these lives on its own fast-loading page, so you can bookmark exactly the tool you use most and get straight to it next time, without wading through menus or unrelated features.
        </p>

        <h3 class="display-sm mb-sm">Built to Be the Best Online Calculator You'll Use</h3>
        <p>
          Plenty of calculator sites exist, but many are slow, cluttered with pop-ups, or hide the actual tool behind banner ads. We set out to build the <strong>best online calculator</strong> experience by stripping all of that away. Every calculation updates live as you type, with no page reloads and no waiting. All of the maths runs directly in your browser, so nothing you type is ever sent to a server — your numbers stay private by default. Add in full keyboard support, screen-reader compatibility, and a responsive layout that adapts to phones, tablets and desktops alike, and you have a genuinely reliable, <strong>best free online calculator</strong> option you can trust for both quick everyday sums and more serious scientific work.
        </p>

        <h3 class="display-sm mb-sm">More Than a Calculator — A Full Online Converter Suite</h3>
        <p>
          Calculations often go hand in hand with conversions, which is why SpotOn also includes a complete <strong>online converter</strong> suite. Convert length between metres, feet and inches, weight between kilograms, pounds and stone, temperature between Celsius, Fahrenheit and Kelvin, and speed, volume, time and ring sizes — all through the same fast, no-nonsense interface. Like our calculators, every online converter tool loads instantly, updates results as you type, and requires no account or download. It's the kind of practical, everyday utility you can lean on for cooking, travel, fitness, home improvement, or study, without switching between half a dozen different websites.
        </p>

        <h3 class="display-sm mb-sm">Is SpotOn Really Free to Use?</h3>
        <p>
          Yes. Every calculator and converter on this site is a genuinely free online calculator tool — there are no premium tiers, no paywalled features, and no limits on how many times you can use it. We don't require an email address, a login, or a credit card, and we don't lock advanced functions like scientific notation or unit conversion behind a subscription. That's part of what makes SpotOn a strong candidate for the best free online calculator you'll find: what you see is what you get, every single time you visit, whether you're on a laptop at your desk or a phone in the middle of a shop.
        </p>

        <p>
          Students, professionals, shoppers, cooks, builders and hobbyists all end up needing an online calculator or online converter at some point, and SpotOn aims to be the tool you reach for every time. There's nothing to download, nothing to configure, and nothing standing between you and your answer. Just open the page, type in your numbers, and get a result you can trust — completely free, on any device, for as long as you need it.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="section section-soft">
    <div class="container" style="text-align:center;">
      <h2 class="display-lg mb-md">Ready to calculate?</h2>
      <p class="body-lg text-body mb-xl" style="max-width:480px; margin-left:auto; margin-right:auto;">Pick a tool and start instantly. No sign-up, no download, no cost.</p>
      <div class="hero-actions">
        <a href="/calculators/simple/" class="btn-primary">Open Calculator</a>
        <a href="/converters/" class="btn-secondary">Browse Converters</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Hero calculator logic
  (function() {
    let display = '0', expr = '', op = '', prev = '', justEval = false;
    const res = document.getElementById('hc-result');
    const exprEl = document.getElementById('hc-expr');

    function update() {
      res.textContent = display.length > 12 ? parseFloat(display).toExponential(4) : display;
      exprEl.textContent = expr;
    }

    document.querySelectorAll('#hero-calc .calc-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const v = btn.dataset.val;
        if (v === 'C') { display = '0'; expr = ''; op = ''; prev = ''; justEval = false; }
        else if (v === '±') { display = String(-parseFloat(display)); }
        else if (v === '%') { display = String(parseFloat(display) / 100); }
        else if (['÷','×','−','+'].includes(v)) {
          prev = display; op = v; expr = display + ' ' + v; display = '0'; justEval = false;
        }
        else if (v === '=') {
          if (!op) return;
          const a = parseFloat(prev), b = parseFloat(display);
          let r = op === '÷' ? a/b : op === '×' ? a*b : op === '−' ? a-b : a+b;
          expr = prev + ' ' + op + ' ' + display + ' =';
          display = String(parseFloat(r.toFixed(10)));
          op = ''; justEval = true;
        }
        else if (v === '.') {
          if (justEval) { display = '0.'; justEval = false; }
          else if (!display.includes('.')) display += '.';
        }
        else {
          if (display === '0' || justEval) { display = v; justEval = false; }
          else display += v;
        }
        update();
      });
    });

    // Filter pills
    document.querySelectorAll('.category-pills .pill').forEach(pill => {
      pill.addEventListener('click', () => {
        document.querySelectorAll('.category-pills .pill').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        const filter = pill.dataset.filter;
        document.querySelectorAll('#tools-grid [data-cat]').forEach(card => {
          card.style.display = (filter === 'all' || card.dataset.cat.includes(filter)) ? '' : 'none';
        });
      });
    });
  })();
</script>
