---
import Layout from '../../layouts/Layout.astro';
const refs = [
  { label: 'Absolute zero', c: '-273.15', f: '-459.67', k: '0' },
  { label: 'Water freezes', c: '0', f: '32', k: '273.15' },
  { label: 'Room temperature', c: '20', f: '68', k: '293.15' },
  { label: 'Body temperature', c: '37', f: '98.6', k: '310.15' },
  { label: 'Water boils', c: '100', f: '212', k: '373.15' },
  { label: 'Oven (moderate)', c: '180', f: '356', k: '453.15' },
];
---
<Layout title="Temperature Conversions — Celsius, Fahrenheit, Kelvin | SpotOn" description="Temperature conversion reference: Celsius to Fahrenheit, Kelvin formula guide and key temperatures. With interactive converter.">
  <section class="tool-page-header">
    <div class="container">
      <div>
        <nav class="breadcrumb"><a href="/">Home</a><span class="breadcrumb-sep">›</span><a href="/converters/">Converters</a><span class="breadcrumb-sep">›</span><span>Temperature Conversions</span></nav>
        <h1 class="display-lg">Temperature Conversions</h1>
        <p class="body-md text-body" style="margin-top:8px;">Celsius, Fahrenheit and Kelvin — formulas and key reference temperatures.</p>
      </div>
      <a href="/converters/temperature/" class="btn-primary" style="flex-shrink:0;">Open Converter →</a>
    </div>
  </section>
  <section class="section section-soft">
    <div class="container">
      <div class="grid-3 mb-xl">
        <div class="card">
          <div class="card-icon card-icon-blue">°C → °F</div>
          <h2 class="body-sm-strong mb-sm">Celsius to Fahrenheit</h2>
          <p style="font-family:var(--font-mono); font-size:14px; color:var(--color-body);">°F = (°C × 9/5) + 32</p>
          <p class="body-sm text-mute" style="margin-top:8px;">Example: 100°C = 212°F</p>
        </div>
        <div class="card">
          <div class="card-icon card-icon-purple">°F → °C</div>
          <h2 class="body-sm-strong mb-sm">Fahrenheit to Celsius</h2>
          <p style="font-family:var(--font-mono); font-size:14px; color:var(--color-body);">°C = (°F − 32) × 5/9</p>
          <p class="body-sm text-mute" style="margin-top:8px;">Example: 32°F = 0°C</p>
        </div>
        <div class="card">
          <div class="card-icon card-icon-cyan">°C → K</div>
          <h2 class="body-sm-strong mb-sm">Celsius to Kelvin</h2>
          <p style="font-family:var(--font-mono); font-size:14px; color:var(--color-body);">K = °C + 273.15</p>
          <p class="body-sm text-mute" style="margin-top:8px;">Example: 0°C = 273.15 K</p>
        </div>
      </div>
      <p class="caption-mono mb-md">Key reference temperatures</p>
      <div style="overflow-x:auto; margin-bottom:32px;">
        <table style="width:100%; border-collapse:collapse;">
          <thead><tr style="border-bottom:2px solid var(--color-hairline);">
            <th style="text-align:left; padding:10px; font-size:12px; font-family:var(--font-mono); color:var(--color-mute);">Temperature</th>
            <th style="text-align:center; padding:10px; font-size:12px; font-family:var(--font-mono); color:var(--color-mute);">°C</th>
            <th style="text-align:center; padding:10px; font-size:12px; font-family:var(--font-mono); color:var(--color-mute);">°F</th>
            <th style="text-align:center; padding:10px; font-size:12px; font-family:var(--font-mono); color:var(--color-mute);">K</th>
          </tr></thead>
          <tbody>
            {refs.map(r => (
              <tr style="border-bottom:1px solid var(--color-hairline);">
                <td style="padding:12px 10px; font-size:14px; font-weight:500;">{r.label}</td>
                <td style="padding:12px 10px; font-size:14px; font-family:var(--font-mono); text-align:center;">{r.c}</td>
                <td style="padding:12px 10px; font-size:14px; font-family:var(--font-mono); text-align:center;">{r.f}</td>
                <td style="padding:12px 10px; font-size:14px; font-family:var(--font-mono); text-align:center;">{r.k}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div style="text-align:center;"><a href="/converters/temperature/" class="btn-primary">Use Interactive Temperature Converter</a></div>
    </div>
  </section>
</Layout>
