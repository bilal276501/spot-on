---
import Layout from '../../layouts/Layout.astro';
const convs = [
  { href:'/converters/length/', icon:'📏', title:'Length Converter', desc:'Metres, feet, inches, miles, km.' },
  { href:'/converters/weight/', icon:'🏋️', title:'Weight Converter', desc:'Kg, pounds, stone, ounces.' },
  { href:'/converters/temperature/', icon:'🌡️', title:'Temperature Converter', desc:'Celsius, Fahrenheit, Kelvin.' },
  { href:'/converters/speed/', icon:'💨', title:'Speed Converter', desc:'MPH, km/h, m/s, knots.' },
  { href:'/converters/volume/', icon:'🧪', title:'Volume Converter', desc:'Litres, gallons, cups, fluid oz.' },
  { href:'/converters/time/', icon:'⏱️', title:'Time Converter', desc:'Seconds to years and everything between.' },
  { href:'/converters/ring-size/', icon:'💍', title:'Ring Size Converter', desc:'UK, US, EU ring size charts.' },
  { href:'/converters/currency/', icon:'💱', title:'Currency Converter', desc:'Live exchange rates, 150+ currencies.' },
];
---
<Layout title="Free Unit Converters — SpotOn Calculator" description="All our free unit converters: length, weight, temperature, speed, volume, time and ring size.">
  <section class="tool-page-header">
    <div class="container">
      <div>
        <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span class="breadcrumb-sep">›</span><span>Converters</span></nav>
        <h1 class="display-lg">Unit Converters</h1>
        <p class="body-md text-body" style="margin-top:8px;max-width:480px;">Instant, accurate unit conversions across all common measurement types.</p>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="tool-search-wrap">
        <input type="text" id="conv-search" class="tool-search" placeholder="Search converters… (e.g. weight, currency, time)" autocomplete="off" />
      </div>
      <div class="grid-3" id="conv-grid">
        {convs.map(c => (
          <a href={c.href} class="card card-link" data-search={(c.title + ' ' + c.desc).toLowerCase()}>
            <div class="card-icon card-icon-purple" style="font-size:22px;">{c.icon}</div>
            <h2 class="body-sm-strong mb-sm">{c.title}</h2>
            <p class="body-sm text-body">{c.desc}</p>
          </a>
        ))}
      </div>
      <p class="body-sm text-mute" id="conv-no-results" style="display:none; text-align:center; margin-top:24px;">No converters match your search.</p>
    </div>
  </section>
</Layout>

<script>
  const searchInput = document.getElementById('conv-search');
  const cards = document.querySelectorAll('#conv-grid .card');
  const noResults = document.getElementById('conv-no-results');

  searchInput.addEventListener('input', () => {
    const q = searchInput.value.trim().toLowerCase();
    let visibleCount = 0;
    cards.forEach(card => {
      const match = !q || card.dataset.search.includes(q);
      card.style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });
    noResults.style.display = visibleCount === 0 ? 'block' : 'none';
  });
</script>