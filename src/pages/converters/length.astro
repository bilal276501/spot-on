---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Length Converter — Metres, Feet, Inches, Miles | SpotOn" description="Free online length converter. Convert between metres, centimetres, kilometres, feet, inches, miles, yards and more instantly.">
  <section class="tool-page-header">
    <div class="container">
      <div>
        <nav class="breadcrumb"><a href="/">Home</a><span class="breadcrumb-sep">›</span><a href="/converters/">Converters</a><span class="breadcrumb-sep">›</span><span>Length</span></nav>
        <h1 class="display-lg">Length Converter</h1>
        <p class="body-md text-body" style="margin-top:8px;">Convert metres, feet, inches, miles, kilometres and more.</p>
      </div>
    </div>
  </section>
  <section class="section section-soft">
    <div class="container" style="display:flex; justify-content:center;">
      <div class="converter-box" style="max-width:600px; width:100%;">
        <div class="converter-row">
          <div class="converter-field"><label>Value</label><input type="number" id="len-val" value="1" step="any" /></div>
          <div class="converter-swap" id="len-swap" title="Swap units">⇄</div>
          <div class="converter-field"><label>Result</label><input type="number" id="len-res" readonly style="background:var(--color-canvas-soft);" /></div>
        </div>
        <div class="converter-unit-row">
          <div class="converter-field"><label>From</label>
            <select id="len-from">
              <option value="1">Metre (m)</option>
              <option value="0.01">Centimetre (cm)</option>
              <option value="0.001">Millimetre (mm)</option>
              <option value="1000">Kilometre (km)</option>
              <option value="0.3048">Foot (ft)</option>
              <option value="0.0254">Inch (in)</option>
              <option value="1609.344">Mile (mi)</option>
              <option value="0.9144">Yard (yd)</option>
              <option value="1852">Nautical Mile</option>
              <option value="1e-10">Angstrom (Å)</option>
              <option value="9.461e15">Light Year (ly)</option>
            </select>
          </div>
          <div class="converter-field"><label>To</label>
            <select id="len-to">
              <option value="0.3048">Foot (ft)</option>
              <option value="1">Metre (m)</option>
              <option value="0.01">Centimetre (cm)</option>
              <option value="0.001">Millimetre (mm)</option>
              <option value="1000">Kilometre (km)</option>
              <option value="0.0254">Inch (in)</option>
              <option value="1609.344">Mile (mi)</option>
              <option value="0.9144">Yard (yd)</option>
              <option value="1852">Nautical Mile</option>
            </select>
          </div>
        </div>
        <!-- Quick reference table -->
        <div style="margin-top:24px; overflow-x:auto;">
          <p class="caption-mono mb-sm">All conversions from <span id="ref-unit">Metre</span></p>
          <table style="width:100%; border-collapse:collapse;" id="len-table">
            <thead><tr style="border-bottom:1px solid var(--color-hairline);">
              <th style="text-align:left; padding:8px 0; font-size:12px; font-family:var(--font-mono); color:var(--color-mute);">Unit</th>
              <th style="text-align:right; padding:8px 0; font-size:12px; font-family:var(--font-mono); color:var(--color-mute);">Value</th>
            </tr></thead>
            <tbody id="len-tbody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
  <section class="content-band"><div class="container"><div class="content-prose">
    <h2>Common length conversions</h2>
    <p>1 metre = 3.28084 feet | 1 kilometre = 0.621371 miles | 1 inch = 2.54 centimetres | 1 mile = 1.60934 kilometres | 1 foot = 12 inches = 30.48 cm.</p>
    <h2>Metric vs Imperial</h2>
    <p>The metric system (SI) uses metres as the base unit. Imperial units (feet, inches, miles) are primarily used in the United States and United Kingdom for some everyday measurements.</p>
  </div></div></section>
</Layout>
<script>
  const units=[{n:'Metre',v:1},{n:'Centimetre',v:0.01},{n:'Millimetre',v:0.001},{n:'Kilometre',v:1000},{n:'Foot',v:0.3048},{n:'Inch',v:0.0254},{n:'Mile',v:1609.344},{n:'Yard',v:0.9144},{n:'Nautical Mile',v:1852}];
  function convert(){
    const val=parseFloat(document.getElementById('len-val').value)||0;
    const from=parseFloat(document.getElementById('len-from').value);
    const to=parseFloat(document.getElementById('len-to').value);
    const res=val*from/to;
    document.getElementById('len-res').value=parseFloat(res.toPrecision(8));
    // table
    const baseVal=val*from;
    const tbody=document.getElementById('len-tbody');
    tbody.innerHTML=units.map(u=>`<tr style="border-bottom:1px solid var(--color-hairline);"><td style="padding:10px 0; font-size:14px; color:var(--color-body);">${u.n}</td><td style="padding:10px 0; font-size:14px; font-family:var(--font-mono); text-align:right;">${parseFloat((baseVal/u.v).toPrecision(7)).toLocaleString()}</td></tr>`).join('');
  }
  ['len-val','len-from','len-to'].forEach(id=>document.getElementById(id).addEventListener('input',convert));
  document.getElementById('len-swap').addEventListener('click',()=>{
    const f=document.getElementById('len-from').value, t=document.getElementById('len-to').value;
    document.getElementById('len-from').value=t; document.getElementById('len-to').value=f;
    document.getElementById('len-val').value=document.getElementById('len-res').value||1;
    convert();
  });
  convert();
</script>
