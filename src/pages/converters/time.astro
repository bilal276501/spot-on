---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Time Converter — Seconds, Minutes, Hours, Days | SpotOn" description="Free online time converter. Convert between seconds, minutes, hours, days, weeks, months and years instantly.">
  <section class="tool-page-header">
    <div class="container">
      <div>
        <nav class="breadcrumb"><a href="/">Home</a><span class="breadcrumb-sep">›</span><a href="/converters/">Converters</a><span class="breadcrumb-sep">›</span><span>Time</span></nav>
        <h1 class="display-lg">Time Converter</h1>
        <p class="body-md text-body" style="margin-top:8px;">Convert seconds, minutes, hours, days, weeks and years.</p>
      </div>
    </div>
  </section>
  <section class="section section-soft">
    <div class="container" style="display:flex; justify-content:center;">
      <div class="converter-box" style="max-width:600px; width:100%;">
        <div class="converter-row">
          <div class="converter-field"><label>Value</label><input type="number" id="ti-val" value="1" step="any" /></div>
          <div class="converter-swap" id="ti-swap">⇄</div>
          <div class="converter-field"><label>Result</label><input type="number" id="ti-res" readonly style="background:var(--color-canvas-soft);" /></div>
        </div>
        <div class="converter-unit-row">
          <div class="converter-field"><label>From</label>
            <select id="ti-from">
              <option value="1">Second (s)</option>
              <option value="60">Minute (min)</option>
              <option value="3600">Hour (hr)</option>
              <option value="86400">Day</option>
              <option value="604800">Week</option>
              <option value="2629800">Month (avg)</option>
              <option value="31557600">Year</option>
              <option value="0.001">Millisecond (ms)</option>
              <option value="0.000001">Microsecond (μs)</option>
            </select>
          </div>
          <div class="converter-field"><label>To</label>
            <select id="ti-to">
              <option value="60">Minute (min)</option>
              <option value="1">Second (s)</option>
              <option value="3600">Hour (hr)</option>
              <option value="86400">Day</option>
              <option value="604800">Week</option>
              <option value="2629800">Month (avg)</option>
              <option value="31557600">Year</option>
            </select>
          </div>
        </div>
        <div style="margin-top:24px;"><p class="caption-mono mb-sm">All conversions</p>
          <table style="width:100%;border-collapse:collapse;"><thead><tr style="border-bottom:1px solid var(--color-hairline);"><th style="text-align:left;padding:8px 0;font-size:12px;font-family:var(--font-mono);color:var(--color-mute);">Unit</th><th style="text-align:right;padding:8px 0;font-size:12px;font-family:var(--font-mono);color:var(--color-mute);">Value</th></tr></thead>
          <tbody id="ti-tbody"></tbody></table>
        </div>
      </div>
    </div>
  </section>
  <section class="content-band"><div class="container"><div class="content-prose">
    <h2>Time conversion reference</h2>
    <p>1 minute = 60 seconds | 1 hour = 3600 seconds | 1 day = 86,400 seconds | 1 week = 604,800 seconds | 1 year ≈ 31,557,600 seconds (365.25 days).</p>
  </div></div></section>
</Layout>
<script>
  const units=[{n:'Millisecond',v:0.001},{n:'Second',v:1},{n:'Minute',v:60},{n:'Hour',v:3600},{n:'Day',v:86400},{n:'Week',v:604800},{n:'Month (avg)',v:2629800},{n:'Year',v:31557600}];
  function convert(){
    const val=parseFloat(document.getElementById('ti-val').value)||0;
    const from=parseFloat(document.getElementById('ti-from').value),to=parseFloat(document.getElementById('ti-to').value);
    document.getElementById('ti-res').value=parseFloat((val*from/to).toPrecision(8));
    const base=val*from;
    document.getElementById('ti-tbody').innerHTML=units.map(u=>`<tr style="border-bottom:1px solid var(--color-hairline);"><td style="padding:10px 0;font-size:14px;color:var(--color-body);">${u.n}</td><td style="padding:10px 0;font-size:14px;font-family:var(--font-mono);text-align:right;">${parseFloat((base/u.v).toPrecision(7)).toLocaleString()}</td></tr>`).join('');
  }
  ['ti-val','ti-from','ti-to'].forEach(id=>document.getElementById(id).addEventListener('input',convert));
  document.getElementById('ti-swap').addEventListener('click',()=>{const f=document.getElementById('ti-from').value,t=document.getElementById('ti-to').value; document.getElementById('ti-from').value=t; document.getElementById('ti-to').value=f; document.getElementById('ti-val').value=document.getElementById('ti-res').value||1; convert();});
  convert();
</script>
