---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}
const {
  title = 'SpotOn Calculator — Free Online Calculators & Unit Converters',
  description = 'Effortlessly convert units, currencies, and more. Free online calculators: scientific, BMI, percentage, patio, darts, and unit converters for length, weight, temperature, speed & more.',
  canonical = Astro.url.href,
} = Astro.props;

const navItems = [
  { label: 'Calculators', href: '/calculators/' },
  { label: 'Converters', href: '/converters/' },
  { label: 'Scientific', href: '/calculators/scientific/' },
  { label: 'BMI', href: '/calculators/bmi/' },
  { label: 'More Tools', href: '/#tools' },
];

const allTools = [
  { href:'/calculators/simple/', icon:'🖩', title:'Simple Calculator' },
  { href:'/calculators/scientific/', icon:'🔬', title:'Scientific Calculator' },
  { href:'/calculators/fullscreen/', icon:'⛶', title:'Fullscreen Calculator' },
  { href:'/calculators/abacus/', icon:'🧮', title:'Online Abacus' },
  { href:'/calculators/bmi/', icon:'⚖️', title:'BMI Calculator' },
  { href:'/calculators/age/', icon:'🎂', title:'Age Calculator' },
  { href:'/calculators/tip/', icon:'💵', title:'Tip Calculator' },
  { href:'/calculators/percentage/', icon:'%', title:'Percentage Calculator' },
  { href:'/calculators/patio/', icon:'🏗️', title:'Patio Calculator' },
  { href:'/calculators/darts/', icon:'🎯', title:'Darts Calculator' },
  { href:'/calculators/maths/', icon:'∑', title:'Maths Calculator' },
  { href:'/converters/length/', icon:'📏', title:'Length Converter' },
  { href:'/converters/weight/', icon:'🏋️', title:'Weight Converter' },
  { href:'/converters/temperature/', icon:'🌡️', title:'Temperature Converter' },
  { href:'/converters/speed/', icon:'💨', title:'Speed Converter' },
  { href:'/converters/volume/', icon:'🧪', title:'Volume Converter' },
  { href:'/converters/time/', icon:'⏱️', title:'Time Converter' },
  { href:'/converters/ring-size/', icon:'💍', title:'Ring Size Converter' },
  { href:'/converters/currency/', icon:'💱', title:'Currency Converter' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon.ico" />
  <script is:inline>
    // Runs before first paint to avoid a light/dark flash.
    (function () {
      try {
        var stored = localStorage.getItem('spoton-theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      } catch (e) {}
    })();
  </script>
  <title>{title}</title>
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "SpotOn Calculator",
    "url": "https://spotoncalculator.com",
    "description": description,
  })} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap" />
  </noscript>
  <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
  <meta property="og:site_name" content="SpotOn Calculator" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
</head>
<body>
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="SpotOn Calculator home">
        <div class="nav-logo-icon">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect x="2" y="2" width="5" height="5" rx="1" fill="white"/>
            <rect x="9" y="2" width="5" height="5" rx="1" fill="white" opacity="0.6"/>
            <rect x="2" y="9" width="5" height="5" rx="1" fill="white" opacity="0.6"/>
            <rect x="9" y="9" width="5" height="5" rx="1" fill="white"/>
          </svg>
        </div>
        SpotOn Calculator
      </a>
      <ul class="nav-links" role="list">
        {navItems.map(item => (
          <li>
            <a href={item.href} class={Astro.url.pathname.startsWith(item.href) ? 'active' : ''}>{item.label}</a>
          </li>
        ))}
      </ul>
      <div class="nav-actions">
        <button class="nav-search-btn" id="nav-search-btn" type="button" aria-label="Search tools">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/>
            <path d="M21 21l-4.3-4.3"/>
          </svg>
        </button>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle dark mode">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <a href="/calculators/simple/" class="btn-primary-sm nav-cta">Launch Calculator</a>
        <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg id="nav-toggle-open" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
            <path d="M2 4.5h14M2 9h14M2 13.5h14"/>
          </svg>
          <svg id="nav-toggle-close" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true" style="display:none;">
            <path d="M3.5 3.5l11 11M14.5 3.5l-11 11"/>
          </svg>
        </button>
      </div>
    </div>
    <div class="mobile-menu" id="mobile-menu">
      <ul class="mobile-menu-links" role="list">
        {navItems.map(item => (
          <li>
            <a href={item.href} class={Astro.url.pathname.startsWith(item.href) ? 'active' : ''}>{item.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <div class="search-overlay" id="search-overlay">
    <div class="search-sheet">
      <div class="search-input-row">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.4; flex-shrink:0;">
          <circle cx="11" cy="11" r="7"/>
          <path d="M21 21l-4.3-4.3"/>
        </svg>
        <input type="text" id="search-input" class="search-input" placeholder="Search all calculators & converters…" autocomplete="off" />
        <button id="search-close" class="search-close" type="button" aria-label="Close search">✕</button>
      </div>
      <div class="search-results" id="search-results"></div>
    </div>
  </div>

  <main>
    <slot />
  </main>

  <footer class="footer" role="contentinfo">
    <div class="footer-inner">
      <div class="footer-grid">
        <div>
          <a href="/" class="nav-logo" style="margin-bottom: 12px; display:inline-flex;">
            <div class="nav-logo-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <rect x="2" y="2" width="5" height="5" rx="1" fill="white"/>
                <rect x="9" y="2" width="5" height="5" rx="1" fill="white" opacity="0.6"/>
                <rect x="2" y="9" width="5" height="5" rx="1" fill="white" opacity="0.6"/>
                <rect x="9" y="9" width="5" height="5" rx="1" fill="white"/>
              </svg>
            </div>
            SpotOn Calculator
          </a>
          <p style="font-size:14px; color: var(--color-body); max-width:240px; margin-top:12px;">
            Free, fast, and beautifully simple calculators and converters for everyday use.
          </p>
        </div>
        <div>
          <p class="footer-col-label">Calculators</p>
          <ul class="footer-links">
            <li><a href="/calculators/simple/">Simple Calculator</a></li>
            <li><a href="/calculators/scientific/">Scientific</a></li>
            <li><a href="/calculators/bmi/">BMI Calculator</a></li>
            <li><a href="/calculators/percentage/">Percentage</a></li>
            <li><a href="/calculators/darts/">Darts</a></li>
            <li><a href="/calculators/patio/">Patio</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-col-label">Converters</p>
          <ul class="footer-links">
            <li><a href="/converters/length/">Length</a></li>
            <li><a href="/converters/weight/">Weight</a></li>
            <li><a href="/converters/temperature/">Temperature</a></li>
            <li><a href="/converters/speed/">Speed</a></li>
            <li><a href="/converters/volume/">Volume</a></li>
            <li><a href="/converters/time/">Time</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-col-label">Tools</p>
          <ul class="footer-links">
            <li><a href="/calculators/abacus/">Online Abacus</a></li>
            <li><a href="/converters/ring-size/">Ring Size</a></li>
            <li><a href="/calculators/fullscreen/">Fullscreen</a></li>
            <li><a href="/converters/">All Converters</a></li>
            <li><a href="/calculators/">All Calculators</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {new Date().getFullYear()} SpotOnCalculator.com — Free online calculators.</span>
        <span style="font-family: var(--font-mono); font-size: 11px;">spotoncalculator.com</span>
      </div>
    </div>
  </footer>

  <script type="application/json" id="all-tools-data" set:html={JSON.stringify(allTools)}></script>
  <script is:inline>
    (function () {
      var overlay = document.getElementById('search-overlay');
      var input = document.getElementById('search-input');
      var resultsEl = document.getElementById('search-results');
      var openBtn = document.getElementById('nav-search-btn');
      var closeBtn = document.getElementById('search-close');
      if (!overlay || !openBtn) return;

      var tools = [];
      try { tools = JSON.parse(document.getElementById('all-tools-data').textContent); } catch (e) {}

      function renderResults(query) {
        var q = query.trim().toLowerCase();
        var matches = q ? tools.filter(function (t) { return t.title.toLowerCase().includes(q); }) : tools;
        if (matches.length === 0) {
          resultsEl.innerHTML = '<p class="search-empty">No tools match "' + query.replace(/</g, '&lt;') + '"</p>';
          return;
        }
        resultsEl.innerHTML = matches.map(function (t) {
          return '<a href="' + t.href + '" class="search-result-item"><span class="search-result-icon">' + t.icon + '</span><span>' + t.title + '</span></a>';
        }).join('');
      }

      function openSearch() {
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
        input.value = '';
        renderResults('');
        setTimeout(function () { input.focus(); }, 50);
      }
      function closeSearch() {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }

      openBtn.addEventListener('click', openSearch);
      closeBtn.addEventListener('click', closeSearch);
      overlay.addEventListener('click', function (e) { if (e.target === overlay) closeSearch(); });
      input.addEventListener('input', function () { renderResults(input.value); });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && overlay.classList.contains('open')) closeSearch();
        if ((e.key === '/' || (e.key === 'k' && (e.metaKey || e.ctrlKey))) && !overlay.classList.contains('open')) {
          var tag = document.activeElement && document.activeElement.tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA') return;
          e.preventDefault();
          openSearch();
        }
      });
    })();
  </script>
  <script is:inline>
    (function () {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var current = document.documentElement.getAttribute('data-theme');
        var next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('spoton-theme', next); } catch (e) {}
      });
    })();
  </script>
  <script is:inline>
    (function () {
      var toggle = document.getElementById('nav-toggle');
      var menu = document.getElementById('mobile-menu');
      var iconOpen = document.getElementById('nav-toggle-open');
      var iconClose = document.getElementById('nav-toggle-close');
      if (!toggle || !menu) return;
      function closeMenu() {
        menu.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
        iconOpen.style.display = 'block';
        iconClose.style.display = 'none';
        document.body.style.overflow = '';
      }
      function openMenu() {
        menu.classList.add('open');
        toggle.setAttribute('aria-expanded', 'true');
        iconOpen.style.display = 'none';
        iconClose.style.display = 'block';
        document.body.style.overflow = 'hidden';
      }
      toggle.addEventListener('click', function () {
        if (menu.classList.contains('open')) closeMenu(); else openMenu();
      });
      menu.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', closeMenu);
      });
      window.addEventListener('resize', function () {
        if (window.innerWidth > 600) closeMenu();
      });
    })();
  </script>
</body>
</html>